@model TaskManagementMVC.Models.TaskModel

@{
    ViewData["Title"] = "Create Task";
}
<div class="container mt-5">
    <div class="row shadow-lg justify-content-center">
        <div class="col-6 mb-5">
            <div class="card-header  text-center">
                <h2>CREATE TASKS</h2>
        </div>
            <form action="@Url.Action("Create", "Task")" method="post">
                <!-- Title -->
                <div class="mb-3">
                                <label class="form-label"><b>Title</b></label>
                    @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                </div>

                <!-- Description -->
                <div class="mb-3">
                                <label class="form-label"><b>Description</b></label>
                    @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3" })
                    @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
                </div>

                <!-- Due Date -->
                <div class="mb-3">
                                <label class="form-label"><b>Due Date</b></label>
                                @Html.TextBoxFor(m => m.DueDate, new { @class = "form-control", type = "date", min = DateTime.Now.ToString("yyyy-MM-dd") })
                    @Html.ValidationMessageFor(m => m.DueDate, "", new { @class = "text-danger" })
                </div>

                <!-- Status Dropdown -->
                <div class="mb-3">
                                <label class="form-label"><b>Status</b></label>
                    @Html.DropDownListFor(m => m.StatusId, ViewBag.StatusList as List<SelectListItem>, " Select Status ", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.StatusId, "", new { @class = "text-danger" })
                </div>

                <!-- Priority Dropdown -->
                <div class="mb-3">
                                <label class="form-label"><b>Priority</b></label>
                    @Html.DropDownListFor(m => m.PriorityId, ViewBag.PriorityList as List<SelectListItem>, " Select Priority ", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.PriorityId, "", new { @class = "text-danger" })
                </div>

                <!-- Submit & Cancel Buttons -->
                <div class="d-flex justify-content-between mb-3">
                    
                            <button type="submit" class="btn btn-primary"><b>Create</b></button>
                            <a href="@Url.Action("Index", "Task")" class="btn btn-secondary"><b>Cancel</b></a>
                </div>
            </form>
        
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
