@model IEnumerable<TaskManagementMVC.Models.TaskModel>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<div >
    <div>
        <h3 class=" d-flex justify-content-center ">TASK LISTS </h3>
    </div>
    <div class=" shadow-lg">

<table class="table table-hover table-striped table-bordered text-center">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Status</th>
            <th>Due Date</th>
            <th>Priority</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in Model)
        {
            <tr>
                <td>@task.Title</td>
                <td>@task.Description</td>
                <td>@task.StatusId</td>
                <td>@task.DueDate.ToString("yyyy-MM-dd")</td>
                <td>@task.PriorityId</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@task.TaskId" class="btn btn-warning">Edit</a>
                    <a href="javascript:void(0);" onclick="confirmDelete('@task.TaskId')" class="btn btn-danger">Delete</a>

                </td>
            </tr>
        }
    </tbody>
</table>

    </div>
</div>

<script>
     function confirmDelete(taskId) {
        if (confirm("Are you sure you want to delete this task?")) {
            window.location.href = '/Task/Delete/' + taskId;
        }
    }
</script>