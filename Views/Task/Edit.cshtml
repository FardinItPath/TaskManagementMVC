@model TaskManagementMVC.Models.TaskModel

@{
    ViewData["Title"] = "Edit Task";
}

<div class="container mt-5">
    <div class="row shadow-lg justify-content-center">
        <div class="col-6 mb-5">
            <div class="card-header text-center">
                <h2>EDIT TASK</h2
            </div>
             <div class="card-body text-start">
                    <form action="@Url.Action("Edit", "Task")" method="post">
                        <!-- Hidden TaskId -->
                        @Html.HiddenFor(m => m.TaskId)

                        <!-- Title -->
                        <div class="mb-3">
                            <label class="form-label"><b>Title</b></label>
                            @Html.TextBoxFor(m => m.Title, new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label class="form-label"><b>Description</b></label>
                            @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3", required = "required" })
                            @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
                        </div>

                        <!-- Due Date -->
                        <div class="mb-3">
                            <label class="form-label"><b>Due Date</b></label>
                            @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date", required = "required", 
                                                min = DateTime.Now.ToString("yyyy-MM-dd") })
@* @Html.TextBoxFor(model => model.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" }) *@
                            @Html.ValidationMessageFor(m => m.DueDate, "", new { @class = "text-danger" })
                        </div>

                        <!-- Status Dropdown -->
                        <div class="mb-3">
                            <label class="form-label"><b>Status</b></label>
                            @Html.DropDownListFor(m => m.StatusId, ViewBag.StatusList as List<SelectListItem>, " Select Status ", 
                                                new { @class = "form-select", required = "required" })
                            @Html.ValidationMessageFor(m => m.StatusId, "", new { @class = "text-danger" })
                        </div>

                        <!-- Priority Dropdown -->
                        <div class="mb-3">
                            <label class="form-label"><b>Priority</b></label>
                            @Html.DropDownListFor(m => m.PriorityId, ViewBag.PriorityList as List<SelectListItem>, " Select Priority ", 
                                                new { @class = "form-select", required = "required" })
                            @Html.ValidationMessageFor(m => m.PriorityId, "", new { @class = "text-danger" })
                        </div>

                        <!-- Submit & Cancel Buttons -->
                        <div class="d-flex justify-content-between  mb-3">

                        <button type="submit" class="btn btn-success">Update</button>
                        <a href="@Url.Action("Index", "Task")" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
