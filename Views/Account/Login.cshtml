@model TaskManagementMVC.Models.UserModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Login";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 rounded " style="width: 100%; max-width: 400px; box-shadow: 0px 4px 50px rgba(0, 0, 255, 0.5);">
        <h3 class="text-center mb-3">Login</h3>

          @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "form" }))
        {
            <div class="form-group mb-3">
                @Html.LabelFor(m => m.UserName)
                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "Enter Username" })
                @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger" })
            </div>

            <div class="form-group mb-3">
                @Html.LabelFor(m => m.Password)
                <div class="input-group">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Enter Password", id = "passwordField"})
                    <button type="button"  class="btn btn-outline-secondary" onclick="togglePassword()">👁️</button>
                    <div class="input-group-append">
                    </div>
                </div>
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="my-3 btn btn-primary btn-block w-100">Login</button>

            <p class="text-center mt-3">
                Don't have an account? @Html.ActionLink("Register here", "Register", "Account")
            </p>
        }

    </div>

</div>

<script>
    function togglePassword() {
        var passwordField = document.getElementById("passwordField");
        passwordField.type = passwordField.type === "password" ? "text" : "password";
    }
</script>